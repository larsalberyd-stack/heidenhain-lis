# ============================================================================
# Heidenhain Lead Intelligence - Environment Variables
# Copy this file to .env and fill in the values
# ============================================================================

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=mysql://user:password@host:port/database_name

# ─── Authentication (OAuth) ─────────────────────────────────────────────────
VITE_APP_ID=your-app-id
OAUTH_SERVER_URL=https://your-oauth-server.example.com
JWT_SECRET=your-jwt-secret-key
OWNER_OPEN_ID=openid-of-initial-admin-user

# ─── LLM / AI Email Generation ──────────────────────────────────────────────
BUILT_IN_FORGE_API_URL=https://forge.manus.im
BUILT_IN_FORGE_API_KEY=your-forge-api-key

# ─── Clay (Data Enrichment) ─────────────────────────────────────────────────
CLAY_API_KEY=your-clay-api-key
CLAY_TABLE_ID=your-clay-table-id

# ─── Make.com (Workflow Automation) ──────────────────────────────────────────
MAKE_WEBHOOK_URL=https://hook.eu1.make.com/your-webhook-path

# ─── Frontend: OAuth Portal ─────────────────────────────────────────────────
VITE_OAUTH_PORTAL_URL=https://your-oauth-portal.example.com

# ─── Frontend: Maps (Google Maps via Proxy) ─────────────────────────────────
VITE_FRONTEND_FORGE_API_URL=https://forge.butterfly-effect.dev
VITE_FRONTEND_FORGE_API_KEY=your-frontend-forge-api-key

# ─── Frontend: Analytics (Umami) ────────────────────────────────────────────
VITE_ANALYTICS_ENDPOINT=https://your-analytics.example.com
VITE_ANALYTICS_WEBSITE_ID=your-website-id
